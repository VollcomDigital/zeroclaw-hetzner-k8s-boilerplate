APP_UID=1000
APP_GID=1000
TZ=UTC

DOMAIN=agents.example.com
OPENWORK_HOST=app.agents.example.com
N8N_HOST=n8n.agents.example.com
SSO_HOST=auth.agents.example.com

TRAEFIK_ACME_EMAIL=platform@example.com

ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_SECRET=replace-with-client-secret
ENTRA_ALLOWED_GROUPS=replace-with-entra-group-object-id
ENTRA_ALLOWED_EMAIL_DOMAINS=example.com
OAUTH2_COOKIE_SECRET=replace-with-32-byte-base64-secret

OPENCLAW_IMAGE=ghcr.io/yourorg/openclaw@sha256:replace-with-published-image-digest
NEMOCLAW_IMAGE=ghcr.io/nvidia/openshell-community/sandboxes/openclaw@sha256:replace-with-published-image-digest
OPENWORK_IMAGE=ghcr.io/your-org/openwork@sha256:replace-with-published-image-digest
VLLM_IMAGE=vllm/vllm-openai@sha256:replace-with-published-image-digest
OP_CONNECT_API_IMAGE=1password/connect-api@sha256:replace-with-published-image-digest
OP_CONNECT_SYNC_IMAGE=1password/connect-sync@sha256:replace-with-published-image-digest
N8N_IMAGE=n8nio/n8n@sha256:replace-with-published-image-digest
QDRANT_IMAGE=qdrant/qdrant@sha256:replace-with-published-image-digest
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_MAX_MODEL_LEN=8192
OPENCLAW_PORT=18789
OPENWORK_PORT=3000
OPENCLAW_LLM_BASE_URL=http://vllm:8000/v1

POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_DB=n8n
N8N_ENCRYPTION_KEY=replace-with-n8n-encryption-key

QDRANT_API_KEY=replace-with-qdrant-api-key

OP_CONNECT_CREDENTIALS_FILE=/opt/1password/1password-credentials.json
OP_CONNECT_TOKEN=replace-with-1password-connect-token
BRIDGE_ACCESS_TOKEN=replace-with-mcp-bridge-bearer-token
BRIDGE_AUDIT_LEDGER_PATH=/var/lib/n8n-bridge/audit-ledger.jsonl
BRIDGE_POLICY_FILE_PATH=/etc/n8n-bridge/policy.json
BRIDGE_ROUTING_FILE_PATH=/etc/n8n-bridge/model-routing.json
BRIDGE_VECTOR_MEMORY_POLICY_FILE_PATH=/etc/n8n-bridge/vector-memory-policy.json
BRIDGE_ROLLOUT_FILE_PATH=/etc/n8n-bridge/rollout.json
BRIDGE_FAILURE_MODE_FILE_PATH=/etc/n8n-bridge/failure-mode.json
BRIDGE_CONFIDENTIAL_EXECUTION_FILE_PATH=/etc/n8n-bridge/confidential-execution.json
BRIDGE_AGENT_CONTROL_PLANE_FILE_PATH=/etc/n8n-bridge/agent-control-plane.json
BRIDGE_COMPLIANCE_PLATFORM_FILE_PATH=/etc/n8n-bridge/compliance-platform.json
BRIDGE_AUTONOMOUS_OPTIMIZATION_FILE_PATH=/etc/n8n-bridge/autonomous-optimization.json

HUGGING_FACE_HUB_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=
