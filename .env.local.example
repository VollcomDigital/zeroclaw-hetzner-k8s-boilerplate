APP_UID=1000
APP_GID=1000
TZ=UTC

OPENWORK_HOST=openwork.localhost
N8N_HOST=n8n.localhost

OPENCLAW_IMAGE=coollabsio/openclaw:latest
NEMOCLAW_IMAGE=ghcr.io/nvidia/openshell-community/sandboxes/openclaw:latest
OPENWORK_IMAGE=ghcr.io/your-org/openwork:latest
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
VLLM_MAX_MODEL_LEN=8192
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_MODEL=qwen2.5-coder:7b
OPENCLAW_PORT=18789
OPENWORK_PORT=3000

POSTGRES_USER=n8n
POSTGRES_PASSWORD=dev-postgres-password
POSTGRES_DB=n8n
N8N_ENCRYPTION_KEY=dev-n8n-encryption-key

QDRANT_API_KEY=dev-qdrant-api-key

OP_CONNECT_CREDENTIALS_FILE=./secrets/1password-credentials.json
OP_CONNECT_TOKEN=dev-connect-token
BRIDGE_ACCESS_TOKEN=dev-mcp-bridge-token
BRIDGE_AUDIT_LEDGER_PATH=/var/lib/n8n-bridge/audit-ledger.jsonl
BRIDGE_POLICY_FILE_PATH=/etc/n8n-bridge/policy.json
BRIDGE_ROUTING_FILE_PATH=/etc/n8n-bridge/model-routing.json
BRIDGE_VECTOR_MEMORY_POLICY_FILE_PATH=/etc/n8n-bridge/vector-memory-policy.json
BRIDGE_ROLLOUT_FILE_PATH=/etc/n8n-bridge/rollout.json
BRIDGE_FAILURE_MODE_FILE_PATH=/etc/n8n-bridge/failure-mode.json
BRIDGE_CONFIDENTIAL_EXECUTION_FILE_PATH=/etc/n8n-bridge/confidential-execution.json
BRIDGE_AGENT_CONTROL_PLANE_FILE_PATH=/etc/n8n-bridge/agent-control-plane.json

HUGGING_FACE_HUB_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=
