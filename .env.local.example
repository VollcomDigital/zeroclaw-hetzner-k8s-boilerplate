APP_UID=1000
APP_GID=1000
TZ=UTC

OPENWORK_HOST=openwork.localhost
OPENCLAW_HOST=openclaw.localhost
N8N_HOST=n8n.localhost

# OpenClaw Control UI: https://docs.openclaw.ai/web/control-ui
# Traefik → http://OPENCLAW_HOST/ → nginx :8080; direct gateway: http://127.0.0.1:OPENCLAW_PORT/
# If the UI says the gateway token is missing: paste OPENCLAW_GATEWAY_TOKEN in Control UI settings, or open
#   http://OPENCLAW_HOST/?token=<OPENCLAW_GATEWAY_TOKEN>   (same token value as below).
# Leave AUTH_PASSWORD empty for local (no browser basic-auth). Set a value to enable nginx basic auth in front of the UI.
OLLAMA_BASE_URL=http://vllm:8000
OPENCLAW_PRIMARY_MODEL=ollama/Qwen/Qwen2.5-Coder-7B-Instruct
OPENCLAW_GATEWAY_BIND=lan
AUTH_USERNAME=admin
AUTH_PASSWORD=
OPENCLAW_GATEWAY_TOKEN=dev-openclaw-gateway-token

OPENCLAW_IMAGE=coollabsio/openclaw:latest
NEMOCLAW_IMAGE=ghcr.io/nvidia/openshell-community/sandboxes/openclaw:latest
# OPENWORK_IMAGE is not used locally: docker-compose.local.yml runs a Python static stub for ./frontend/openwork.
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
VLLM_MAX_MODEL_LEN=8192
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_MODEL=qwen2.5-coder:7b
OPENCLAW_PORT=18789
OPENWORK_PORT=3000

POSTGRES_USER=n8n
POSTGRES_PASSWORD=dev-postgres-password
POSTGRES_DB=n8n
N8N_ENCRYPTION_KEY=dev-n8n-encryption-key

QDRANT_API_KEY=dev-qdrant-api-key

OP_CONNECT_CREDENTIALS_FILE=./secrets/1password-credentials.json
OP_CONNECT_TOKEN=dev-connect-token
BRIDGE_ACCESS_TOKEN=dev-mcp-bridge-token
BRIDGE_AUDIT_LEDGER_PATH=/var/lib/n8n-bridge/audit-ledger.jsonl
BRIDGE_MCP_POLICY_CONFIG_PATH=/etc/n8n-bridge/policy.json
BRIDGE_MODEL_ROUTING_CONFIG_PATH=/etc/n8n-bridge/model-routing.json
BRIDGE_VECTOR_MEMORY_CONFIG_PATH=/etc/n8n-bridge/vector-memory-policy.json
BRIDGE_PROGRESSIVE_ROLLOUT_CONFIG_PATH=/etc/n8n-bridge/rollout.json
BRIDGE_FAILURE_MODE_CONFIG_PATH=/etc/n8n-bridge/failure-mode.json
BRIDGE_CONFIDENTIAL_EXECUTION_CONFIG_PATH=/etc/n8n-bridge/confidential-execution.json
BRIDGE_AGENT_CONTROL_PLANE_CONFIG_PATH=/etc/n8n-bridge/agent-control-plane.json
BRIDGE_COMPLIANCE_PLATFORM_CONFIG_PATH=/etc/n8n-bridge/compliance-platform.json
BRIDGE_AUTONOMOUS_OPTIMIZATION_CONFIG_PATH=/etc/n8n-bridge/autonomous-optimization.json
BRIDGE_SOVEREIGNTY_CONFIG_PATH=/etc/n8n-bridge/sovereignty.json

HUGGING_FACE_HUB_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=
